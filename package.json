{
  "name": "katei-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/katei",
    "start:katei": "npm run start -w apps/katei",
    "build:katei:css": "npm run build:css -w apps/katei",
    "prepare:subtree:katei": "npm run build:katei:css",
    "build": "npm run build:katei:css"
  }
}

# Let the server know if you are in 'development' or 'production' you should set this as an environment variable in the Heroku dashboard of your app.
NODE_ENV=development

# Server port, you must not set it manually when deploying to Heroku, as it provides process.env.PORT so it must only be used for local testing
PORT=3000

# Google Identity Services OAuth client ID used by the landing page sign-in flow.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# Secret used to sign the Katei session cookie.
KATEI_SESSION_SECRET=replace-with-a-long-random-string

# Secret used to encrypt board-scoped AI credentials before persistence.
KATEI_BOARD_SECRET_ENCRYPTION_KEY=

# Optional comma-separated allowlist of Google `sub` identifiers. Leave blank to allow any verified account.
GOOGLE_ALLOWLIST_SUBS=

# Optional session duration for the Katei session cookie. Defaults to 7 days.
SESSION_TTL_SECONDS=604800

# Optional canonical app URL used to validate sign-in request origins in production. Local development defaults to http://localhost:3000; set this explicitly outside development when origin validation matters.
APP_BASE_URL=http://localhost:3000

# Optional guarded hosted debug login toggle. When true, POST /__debug/login can mint a Katei session for the configured debug viewer.
KATEI_DEBUG_AUTH_ENABLED=false

# Shared secret required in the x-katei-debug-auth request header when debug auth is enabled.
KATEI_DEBUG_AUTH_SECRET=

# Required Google sub for the debug viewer when hosted debug auth is enabled.
KATEI_DEBUG_AUTH_VIEWER_SUB=

# Optional email for the debug viewer session. Defaults to test@example.com when omitted.
KATEI_DEBUG_AUTH_VIEWER_EMAIL=test@example.com

# Optional display name for the debug viewer session. Defaults to John Doe when omitted.
KATEI_DEBUG_AUTH_VIEWER_NAME=John Doe

# Required MongoDB connection string used for server-owned workspace persistence.
MONGODB_URI=mongodb://127.0.0.1:27017

# Required MongoDB database name used for server-owned workspace persistence.
MONGODB_DB_NAME=katei_test

# set HEROKU_KATEI_APP_PROD as a GitHub repository secret, it should be the name of the app you created in Heroku
HEROKU_APP_NAME=HEROKU_KATEI_APP_PROD

# Replace YOUR_HEROKU_API_KEY with a real Heroku API key as a Github Repository secret
HEROKU_API_KEY=YOUR_HEROKU_API_KEY

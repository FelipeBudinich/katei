<dialog
  class="sheet-dialog"
  data-controller="profile-options"
  data-profile-options-target="dialog"
  data-action="
    workspace:open-profile-options@window->profile-options#openFromEvent
    click->profile-options#backdropClose
    cancel->profile-options#close
  "
>
  {% set profileUiLocalePickerId = profileOptionsUiLocalePickerId or 'profile-options-ui-locale-picker' %}
  {% set profileUiLocalePickerAction = profileOptionsUiLocalePickerAction or uiLocalePickerAction or '/' %}
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div class="min-w-0">
        <p class="field-label text-sm font-semibold">{{ t('profileOptionsDialog.sectionLabel') }}</p>
      </div>

      <button
        type="button"
        class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--close"
        aria-label="{{ t('common.close') }}"
        data-profile-options-initial-focus
        data-action="profile-options#close"
      >
        <span class="sr-only">{{ t('common.close') }}</span>
      </button>
    </div>

    <div class="profile-options-identity-row mt-4">
      <div class="min-w-0">
        {% include "partials/viewer-chip.njk" %}
      </div>

      <div class="profile-options-locale-slot">
        {% set uiLocalePickerId = profileUiLocalePickerId %}
        {% set uiLocalePickerAction = profileUiLocalePickerAction %}
        {% set uiLocalePickerVariant = 'icon-modal' %}
        {% set uiLocalePickerBadgeValue = uiLocaleCurrent.label %}
        {% include "partials/ui-locale-picker.njk" %}
      </div>

      <div
        class="dialog-actions"
        data-controller="session"
        data-session-auth-url-value="/auth/logout"
        data-session-redirect-url-value="{{ profileOptionsSessionRedirectUrl or '/' }}"
      >
        <button
          type="button"
          class="touch-button-secondary"
          data-session-target="logoutButton"
          data-action="session#openLogoutConfirm"
        >
          {{ t('common.logout') }}
        </button>
        <dialog
          class="sheet-dialog confirm-dialog"
          data-session-target="confirmDialog"
          data-action="click->session#backdropCloseConfirmDialog cancel->session#closeConfirmDialog"
        >
          <div class="confirm-panel">
            <div class="space-y-2">
              <h2 class="font-serif text-3xl text-strong" data-session-target="confirmTitle">
                {{ t('session.logoutConfirmTitle') }}
              </h2>
              <p class="text-sm leading-6 text-muted" data-session-target="confirmMessage">
                {{ t('session.logoutConfirmMessage') }}
              </p>
            </div>

            <div class="confirm-actions dialog-actions mt-6">
              <button
                type="button"
                class="touch-button-secondary"
                data-action="session#closeConfirmDialog"
              >
                {{ t('common.cancel') }}
              </button>
              <button
                type="button"
                class="touch-button-danger"
                data-session-target="confirmButton"
                data-action="session#confirmLogout"
              >
                {{ t('common.logout') }}
              </button>
            </div>
          </div>
        </dialog>
        <p class="sr-only" aria-live="polite" data-session-target="status"></p>
      </div>
    </div>
  </div>
</dialog>

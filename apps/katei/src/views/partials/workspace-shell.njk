{% set activeBoard = workspace.boards[workspace.ui.activeBoardId] %}
{% set board = board or activeBoard %}

<main
  class="mx-auto grid min-h-screen w-full max-w-7xl content-start gap-4 px-4 pb-10 pt-4 sm:px-6 lg:px-8"
  data-controller="workspace"
  data-workspace-viewer-sub-value="{{ viewer.sub }}"
  data-workspace-viewer-email-value="{{ viewer.email or '' }}"
  data-action="
    card-editor:save->workspace#handleCardEditorSave
    card-editor:request-locale->workspace#handleCardLocaleRequest
    card-editor:clear-locale-request->workspace#handleCardLocaleRequestClear
    board-editor:save->workspace#handleBoardEditorSave
    board-options:switch-board->workspace#handleBoardSwitch
    board-options:create-board->workspace#openCreateBoard
    board-options:rename-board->workspace#openRenameBoard
    board-options:delete-board->workspace#confirmDeleteBoard
    board-options:reset-board->workspace#confirmResetBoard
    board-options:open-collaborators->workspace#openBoardCollaborators
    board-collaborators:invite-member->workspace#handleInviteMember
    board-collaborators:revoke-invite->workspace#handleRevokeInvite
    board-collaborators:change-member-role->workspace#handleChangeMemberRole
    board-collaborators:remove-member->workspace#handleRemoveMember
    board-collaborators:accept-invite->workspace#handleAcceptInvite
    board-collaborators:decline-invite->workspace#handleDeclineInvite
  "
>
  {% if board %}
    {% include "partials/board-shell.njk" %}
  {% else %}
    <header class="top-bar">
      <div class="top-bar-heading-group">
        {% if viewer %}
          <div class="viewer-chip">
            {% if viewer.picture %}
              <img
                src="{{ viewer.picture }}"
                alt=""
                class="viewer-chip-avatar"
                width="44"
                height="44"
                loading="lazy"
                referrerpolicy="no-referrer"
              >
            {% else %}
              <span class="viewer-chip-avatar viewer-chip-avatar--fallback" aria-hidden="true">
                {{ (viewer.name or viewer.sub) | first | upper }}
              </span>
            {% endif %}
            <div class="viewer-chip-copy">
              <span class="viewer-chip-label">{{ t('workspace.viewerSignedIn') }}</span>
              <span class="viewer-chip-name">{{ viewer.name or viewer.sub }}</span>
            </div>
          </div>
        {% endif %}

        <h1 class="top-bar-title font-serif text-3xl leading-tight text-strong" data-workspace-target="boardTitle">
          {{ t('workspace.noVisibleBoardsTitle') }}
        </h1>
      </div>

      <div class="top-bar-actions">
        <button type="button" class="touch-button-secondary" data-action="workspace#openBoardOptions">
          {{ t('workspace.boardOptions') }}
        </button>
        <button
          type="button"
          class="touch-button-primary"
          data-workspace-target="createCardButton"
          data-action="workspace#openCreateCard"
          hidden
          aria-disabled="true"
        >
          {{ t('workspace.addCard') }}
        </button>
      </div>
    </header>

    <p class="paper-panel px-4 py-4 text-sm leading-6 text-muted" data-workspace-target="boardAccessNotice">
      {{ t('workspace.noVisibleBoardsDescription') }}
    </p>

    <section class="board-columns grid gap-4" data-workspace-target="desktopColumns" hidden></section>
  {% endif %}

  <div class="sr-only" aria-live="polite" data-workspace-target="announcer"></div>

  {% include "partials/card-editor-sheet.njk" %}
  {% include "partials/card-view-dialog.njk" %}
  {% include "partials/board-options-dialog.njk" %}
  {% include "partials/board-collaborators-sheet.njk" %}
  {% include "partials/board-editor-sheet.njk" %}
  {% include "partials/confirm-dialog.njk" %}
  {% include "partials/board-templates.njk" %}
</main>

{% if workspaceBootstrapJson %}
  <script type="application/json" id="workspace-bootstrap">{{ workspaceBootstrapJson | safe }}</script>
{% endif %}

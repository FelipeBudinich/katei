<dialog
  class="sheet-dialog"
  data-controller="card-editor"
  data-action="workspace:open-card-editor@window->card-editor#openFromEvent workspace:card-localization-generation-finished@window->card-editor#finishLocaleGeneration click->card-editor#handleDialogClick"
  data-card-editor-target="dialog"
>
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div>
        <h2 class="font-serif text-3xl text-strong" data-card-editor-target="heading">{{ t('cardEditor.newHeading') }}</h2>
      </div>

      <div class="flex items-center gap-2">
        <div data-card-editor-target="submitActions">
          <button type="submit" form="card-editor-form" class="touch-button-primary">
            {{ t('cardEditor.saveButton') }}
          </button>
        </div>

        {% set statusPickerController = 'card-editor' %}
        {% set statusPickerPrefix = 'card-editor' %}
        {% set statusPickerFormId = 'card-editor-form' %}
        {% set statusPickerSectionTarget = 'statusSection' %}
        {% set statusPickerButtonTarget = 'statusButton' %}
        {% set statusPickerMenuTarget = 'statusMenu' %}
        {% set statusPickerOptionTemplateTarget = 'statusOptionTemplate' %}
        {% set statusPickerOptionTarget = 'statusOption' %}
        {% set statusPickerSelectTarget = 'statusSelect' %}
        {% set statusPickerToggleAction = 'toggleStatusMenu' %}
        {% set statusPickerTriggerKeydownAction = 'handleStatusTriggerKeydown' %}
        {% set statusPickerMenuKeydownAction = 'handleStatusMenuKeydown' %}
        {% set statusPickerOptionAction = 'selectStage' %}
        {% set statusPickerSelectAction = 'changeStatusFromSelect' %}
        {% include "partials/card-status-picker.njk" %}

        <div class="view-locale-picker" hidden data-card-editor-target="prioritySection">
          <button
            type="button"
            id="card-editor-priority-trigger"
            class="touch-button-secondary touch-button-secondary--icon"
            aria-label="{{ t('cardEditor.priorityLabel') }}"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="card-editor-priority-menu"
            data-card-editor-target="priorityButton"
            data-action="click->card-editor#togglePriorityMenu keydown->card-editor#handlePriorityTriggerKeydown"
          >
            <img src="/traffic.svg" alt="" aria-hidden="true" class="touch-button-secondary__icon">
            <span class="sr-only">{{ t('cardEditor.priorityLabel') }}</span>
          </button>

          <div
            id="card-editor-priority-menu"
            class="view-locale-menu"
            role="menu"
            aria-label="{{ t('cardEditor.priorityGroupAriaLabel') }}"
            hidden
            data-card-editor-target="priorityMenu"
            data-action="keydown->card-editor#handlePriorityMenuKeydown"
          >
            {% for priority in priorityDefinitions %}
              <button
                type="button"
                class="view-locale-menu-option view-locale-menu-option--priority"
                value="{{ priority.id }}"
                data-card-editor-target="priorityOption"
                data-priority-id="{{ priority.id }}"
                data-priority-label="{{ priority.label }}"
                role="menuitemradio"
                aria-checked="false"
                tabindex="-1"
                data-action="card-editor#selectPriority"
              >
                {{ priority.label }}
              </button>
            {% endfor %}
          </div>

          <label class="sr-only" for="card-editor-priority-select">{{ t('cardEditor.priorityLabel') }}</label>
          <select
            id="card-editor-priority-select"
            name="priority"
            form="card-editor-form"
            class="sr-only"
            hidden
            tabindex="-1"
            aria-hidden="true"
            data-card-editor-target="priorityInput prioritySelect"
            data-action="change->card-editor#changePriorityFromSelect"
          >
            {% for priority in priorityDefinitions %}
              <option value="{{ priority.id }}"{% if priority.id == 'important' %} selected{% endif %}>
                {{ priority.label }}
              </option>
            {% endfor %}
          </select>
        </div>

        <button
          type="button"
          class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--close"
          aria-label="{{ t('common.close') }}"
          data-action="card-editor#close"
        >
          <span class="sr-only">{{ t('common.close') }}</span>
        </button>
      </div>
    </div>

    <form id="card-editor-form" class="mt-6 space-y-4" data-card-editor-target="form" data-action="submit->card-editor#submit">
      <input type="hidden" name="mode" value="create" data-card-editor-target="modeInput">
      <input type="hidden" name="boardId" value="" data-card-editor-target="boardIdInput">
      <input type="hidden" name="cardId" value="" data-card-editor-target="cardIdInput">
      <input type="hidden" name="sourceStageId" value="" data-card-editor-target="sourceStageIdInput">
      <input type="hidden" name="targetStageId" value="backlog" data-card-editor-target="targetStageIdInput">
      <section class="space-y-3" hidden data-card-editor-target="localeSection">
        <div class="space-y-2">
          <label class="block space-y-2">
            <span class="field-label text-sm font-semibold">{{ t('cardEditor.localeLabel') }}</span>
            <select
              name="locale"
              class="field-control"
              data-action="change->card-editor#changeLocale"
              data-card-editor-target="localeSelect"
            ></select>
          </label>

          <p class="text-sm leading-6 text-muted" aria-live="polite" data-card-editor-target="localeSummary"></p>
          <p class="text-sm leading-6 text-muted" aria-live="polite" hidden data-card-editor-target="localeFallbackNotice"></p>
          <p class="text-sm leading-6 text-strong" aria-live="polite" data-card-editor-target="localeEditSummary"></p>
          <p class="text-sm leading-6 text-strong" aria-live="polite" hidden data-card-editor-target="localeReviewState"></p>
          <p class="text-sm leading-6 text-muted" aria-live="polite" hidden data-card-editor-target="localeReadOnlyNotice"></p>

          <div class="action-wrap-grid">
            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-card-editor-target="generateLocaleButton"
              data-action="card-editor#generateSelectedLocale"
            >
              {{ t('cardEditor.generateLocaleButton') }}
            </button>

            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-card-editor-target="discardLocaleButton"
              data-action="card-editor#discardSelectedLocale"
            >
              {{ t('cardEditor.discardLocaleButton') }}
            </button>

            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-card-editor-target="requestLocaleButton"
              data-action="card-editor#requestSelectedLocale"
            >
              {{ t('cardEditor.requestLocaleButton') }}
            </button>

            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-card-editor-target="clearLocaleRequestButton"
              data-action="card-editor#clearSelectedLocaleRequest"
            >
              {{ t('cardEditor.clearLocaleRequestButton') }}
            </button>

            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-card-editor-target="verifyLocaleButton"
              data-action="card-editor#verifySelectedLocale"
            >
              {{ t('cardEditor.verifyLocaleButton') }}
            </button>
          </div>

          <p class="text-sm leading-6 text-muted" aria-live="polite" hidden data-card-editor-target="generateLocaleHelp"></p>
        </div>
      </section>

      <label class="block space-y-2">
        <span class="field-label text-sm font-semibold">{{ t('cardEditor.titleLabel') }}</span>
        <input
          type="text"
          name="title"
          class="field-control"
          placeholder="{{ t('cardEditor.titlePlaceholder') }}"
          required
          data-card-editor-target="titleInput"
        >
      </label>

      <label class="block space-y-2">
        <textarea
          name="detailsMarkdown"
          rows="8"
          class="field-control"
          placeholder="{{ t('cardEditor.detailsPlaceholder') }}"
          data-card-editor-target="markdownInput"
        ></textarea>
      </label>
    </form>
  </div>
</dialog>

<dialog
  class="sheet-dialog"
  data-controller="board-editor"
  data-board-editor-target="dialog"
  data-action="
    workspace:open-board-editor@window->board-editor#openFromEvent
    click->board-editor#backdropClose
    cancel->board-editor#close
  "
>
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div>
        <h2 class="font-serif text-3xl text-strong" data-board-editor-target="heading">{{ t('boardEditor.newHeading') }}</h2>
      </div>
      <button type="button" class="touch-button-secondary" data-action="board-editor#close">{{ t('common.close') }}</button>
    </div>

    <form class="mt-6 space-y-5" data-board-editor-target="form" data-action="submit->board-editor#submit">
      <input type="hidden" name="mode" value="create" data-board-editor-target="modeInput">
      <input type="hidden" name="boardId" value="" data-board-editor-target="boardIdInput">

      <label class="block space-y-2">
        <span class="field-label text-sm font-semibold">{{ t('boardEditor.titleLabel') }}</span>
        <input
          type="text"
          name="title"
          class="field-control"
          placeholder="{{ t('boardEditor.titlePlaceholder') }}"
          required
          data-board-editor-target="titleInput"
        >
      </label>

      <section class="space-y-3">
        <div class="space-y-1">
          <p class="field-label text-sm font-semibold">{{ t('boardEditor.languagePolicyLabel') }}</p>
          <p class="text-xs leading-5 text-muted">{{ t('boardEditor.languagePolicyHelp') }}</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block space-y-2">
            <span class="field-label text-sm font-semibold">{{ t('boardEditor.sourceLocaleLabel') }}</span>
            <input
              type="text"
              name="sourceLocale"
              class="field-control"
              placeholder="en"
              required
              data-board-editor-target="sourceLocaleInput"
            >
          </label>

          <label class="block space-y-2">
            <span class="field-label text-sm font-semibold">{{ t('boardEditor.defaultLocaleLabel') }}</span>
            <input
              type="text"
              name="defaultLocale"
              class="field-control"
              placeholder="en"
              required
              data-board-editor-target="defaultLocaleInput"
            >
          </label>
        </div>

        <label class="block space-y-2">
          <span class="field-label text-sm font-semibold">{{ t('boardEditor.supportedLocalesLabel') }}</span>
          <textarea
            name="supportedLocales"
            rows="2"
            class="field-control"
            placeholder="en, ja"
            required
            data-board-editor-target="supportedLocalesInput"
          ></textarea>
        </label>

        <label class="block space-y-2">
          <span class="field-label text-sm font-semibold">{{ t('boardEditor.requiredLocalesLabel') }}</span>
          <textarea
            name="requiredLocales"
            rows="2"
            class="field-control"
            placeholder="en"
            data-board-editor-target="requiredLocalesInput"
          ></textarea>
        </label>
      </section>

      <section class="space-y-3" hidden data-board-editor-target="aiSection">
        <div class="space-y-1">
          <p class="field-label text-sm font-semibold">{{ t('boardEditor.aiLocalizationLabel') }}</p>
          <p class="text-xs leading-5 text-muted">{{ t('boardEditor.aiLocalizationHelp') }}</p>
        </div>

        <label class="block space-y-2">
          <span class="field-label text-sm font-semibold">{{ t('boardEditor.aiProviderLabel') }}</span>
          <input
            type="text"
            name="aiProvider"
            class="field-control"
            value="OpenAI"
            readonly
            data-board-editor-target="aiProviderInput"
          >
        </label>

        <label class="block space-y-2">
          <span class="field-label text-sm font-semibold">{{ t('boardEditor.openAiApiKeyLabel') }}</span>
          <input
            type="password"
            name="openAiApiKey"
            class="field-control"
            autocomplete="off"
            spellcheck="false"
            data-board-editor-target="openAiApiKeyInput"
          >
          <p class="text-xs leading-5 text-muted">{{ t('boardEditor.openAiApiKeyHelp') }}</p>
          <p class="text-xs leading-5 text-muted" hidden data-board-editor-target="apiKeyStatus"></p>
        </label>

        <label class="block space-y-2">
          <span class="field-label text-sm font-semibold">{{ t('boardEditor.localizationGlossaryLabel') }}</span>
          <textarea
            name="localizationGlossary"
            rows="4"
            class="field-control font-mono text-sm"
            placeholder="Omen of Sorrow | es=Omen of Sorrow"
            data-board-editor-target="localizationGlossaryInput"
          ></textarea>
          <p class="text-xs leading-5 text-muted">{{ t('boardEditor.localizationGlossaryHelp') }}</p>
        </label>

        <label class="flex items-start gap-3 text-sm leading-6 text-strong">
          <input
            type="checkbox"
            name="clearOpenAiApiKey"
            value="true"
            data-board-editor-target="clearOpenAiApiKeyInput"
          >
          <span>{{ t('boardEditor.clearOpenAiApiKeyLabel') }}</span>
        </label>
      </section>

      <label class="block space-y-2">
        <span class="field-label text-sm font-semibold">{{ t('boardEditor.stagesLabel') }}</span>
        <p class="text-xs leading-5 text-muted">{{ t('boardEditor.stagesHelp') }}</p>
        <textarea
          name="stageDefinitions"
          rows="7"
          class="field-control font-mono text-sm"
          placeholder="archived | Archived | backlog, doing, done | card.delete"
          required
          data-board-editor-target="stageDefinitionsInput"
        ></textarea>
      </label>

      <p class="text-sm leading-6" style="color: var(--color-danger);" hidden data-board-editor-target="error"></p>

      <section class="pt-2" hidden data-board-editor-target="deleteActions">
        <div class="action-wrap-grid">
          <button
            type="button"
            class="touch-button-danger"
            data-board-editor-target="deleteButton"
            data-action="board-editor#closeForAction workspace#confirmDeleteBoard"
          >
            {{ t('boardEditor.deleteButton') }}
          </button>
        </div>
      </section>

      <div class="dialog-actions pt-2">
        <button type="submit" class="touch-button-primary" data-board-editor-target="submitButton">
          {{ t('boardEditor.saveButton') }}
        </button>
      </div>
    </form>
  </div>
</dialog>

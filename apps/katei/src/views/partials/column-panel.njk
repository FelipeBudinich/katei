{% set canCreateInStage = boardCanEdit and column.actionIds and ('card.create' in column.actionIds) %}
<section class="column-panel" data-stage-id="{{ column.id }}" data-column-id="{{ column.id }}" data-collapsed="false">
  <header class="column-panel-header">
    <div class="column-header-row">
      <button
        type="button"
        class="column-header-toggle column-header-toggle-title-button"
        data-column-toggle
        data-stage-id="{{ column.id }}"
        data-column-id="{{ column.id }}"
        data-action="workspace#toggleColumn"
        aria-expanded="true"
        aria-controls="column-panel-body-{{ column.id }}"
      >
        <span class="column-header-toggle-title font-serif text-2xl text-strong" data-column-field="title">
          {{ column.title }}
        </span>
      </button>
      <button
        type="button"
        class="column-header-chip-control column-header-create"
        data-column-create
        data-stage-id="{{ column.id }}"
        data-column-id="{{ column.id }}"
        data-action="workspace#openCreateCard"
        {% if not canCreateInStage %}hidden disabled aria-disabled="true"{% else %}aria-disabled="false"{% endif %}
      >
        <span class="count-chip px-3 py-1 text-sm font-medium">
          <span>{{ t('workspace.addCard') }}</span>
        </span>
      </button>
      <button
        type="button"
        class="column-header-toggle column-header-chip-control column-header-toggle-chip-button"
        data-column-toggle
        data-stage-id="{{ column.id }}"
        data-column-id="{{ column.id }}"
        data-action="workspace#toggleColumn"
        aria-expanded="true"
        aria-controls="column-panel-body-{{ column.id }}"
      >
        <span class="count-chip px-3 py-1 text-sm font-medium" aria-label="{{ t('workspace.cardCount', { count: column.cardIds.length }) }}">
          <span data-column-field="count">{{ column.cardIds.length }}</span>
          <span class="count-chip-icon" aria-hidden="true"></span>
          <span class="column-header-chevron" aria-hidden="true">▾</span>
        </span>
      </button>
    </div>
  </header>

  <div id="column-panel-body-{{ column.id }}" class="column-panel-body"{% if not column.cardIds.length %} hidden{% endif %}>
    <div class="column-card-list space-y-3" data-column-cards>
      {% if column.cardIds.length %}
        {% for cardId in column.cardIds %}
          {% set card = board.cards[cardId] %}
          {% set columnId = column.id %}
          {% include "partials/card-item.njk" %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

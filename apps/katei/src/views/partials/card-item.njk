<article class="card-item" data-card-id="{{ card.id }}" data-stage-id="{{ columnId }}" data-column-id="{{ columnId }}" data-priority="{{ card.priority }}">
  <header
    class="card-item-toolbar"
    data-action="click->workspace#openViewFromToolbar keydown->workspace#openViewFromToolbarKeydown"
    data-card-id="{{ card.id }}"
    data-stage-id="{{ columnId }}"
    data-column-id="{{ columnId }}"
    role="button"
    tabindex="0"
    aria-label="{{ t('cardItem.viewAriaLabel') }}"
  >
    <h3 class="card-item-title text-base text-strong" data-card-field="title">{{ card.title }}</h3>
  </header>

  <div class="card-item-body">
    <p
      class="text-sm leading-6 text-muted{% if not card.detailsMarkdown %} hidden{% endif %}"
      data-card-field="preview"
    >
      {{ card.detailsMarkdown }}
    </p>
  </div>

  <footer class="card-item-footer">
    <p class="card-item-meta text-xs uppercase tracking-[0.24em] text-subtle">
      <span class="card-item-meta-icon" aria-hidden="true"></span>
      <span data-card-field="meta">{{ card.updatedAt }}</span>
    </p>
  </footer>
</article>

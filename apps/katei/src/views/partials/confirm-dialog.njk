<dialog
  class="sheet-dialog confirm-dialog"
  data-workspace-target="confirmDialog"
  data-action="click->workspace#backdropCloseConfirmDialog cancel->workspace#closeConfirmDialog"
>
  <div class="confirm-panel">
    <div class="space-y-2">
      <h2 class="font-serif text-3xl text-strong" data-workspace-target="confirmTitle">
        {{ t('confirmDialog.deleteCardTitle') }}
      </h2>
      <p class="text-sm leading-6 text-muted" data-workspace-target="confirmMessage">
        {{ t('confirmDialog.deleteCardMessage') }}
      </p>
    </div>

    <div class="confirm-actions dialog-actions mt-6">
      <button type="button" class="touch-button-secondary" data-action="workspace#closeConfirmDialog">
        {{ t('common.cancel') }}
      </button>
      <button type="button" class="touch-button-danger" data-workspace-target="confirmButton" data-action="workspace#confirmPendingAction">
        {{ t('common.delete') }}
      </button>
    </div>
  </div>
</dialog>

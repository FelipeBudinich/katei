<dialog
  class="sheet-dialog"
  data-workspace-target="viewDialog"
  data-action="click->workspace#handleViewDialogClick"
>
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div class="min-w-0 space-y-2">
        <div class="space-y-2" data-workspace-target="viewCardPrioritySection">
          <dd class="text-sm leading-6 text-strong" data-workspace-target="viewCardPriority"></dd>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <button
          type="button"
          class="touch-button-danger"
          hidden
          disabled
          aria-disabled="true"
          data-workspace-target="viewDeleteButton"
          data-action="workspace#deleteCard"
        >
          {{ t('common.delete') }}
        </button>

        <button
          type="button"
          class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--prompt"
          hidden
          aria-label="{{ t('workspace.cardPromptRunButton') }}"
          data-workspace-target="viewPromptRunButton"
          data-action="workspace#handleRunStagePromptFromView"
        >
          <span class="sr-only">{{ t('workspace.cardPromptRunButton') }}</span>
        </button>

        {% set statusPickerController = 'workspace' %}
        {% set statusPickerPrefix = 'card-view' %}
        {% set statusPickerFormId = null %}
        {% set statusPickerSectionTarget = 'viewStatusSection' %}
        {% set statusPickerButtonTarget = 'viewStatusButton' %}
        {% set statusPickerMenuTarget = 'viewStatusMenu' %}
        {% set statusPickerOptionTemplateTarget = 'viewStatusOptionTemplate' %}
        {% set statusPickerOptionTarget = 'viewStatusOption' %}
        {% set statusPickerSelectTarget = 'viewStatusSelect' %}
        {% set statusPickerToggleAction = 'toggleViewStatusMenu' %}
        {% set statusPickerTriggerKeydownAction = 'handleViewStatusTriggerKeydown' %}
        {% set statusPickerMenuKeydownAction = 'handleViewStatusMenuKeydown' %}
        {% set statusPickerOptionAction = 'changeViewStatus' %}
        {% set statusPickerSelectAction = 'changeViewStatus' %}
        {% include "partials/card-status-picker.njk" %}

        <div hidden data-workspace-target="viewLocaleSection">
          <div class="view-locale-picker">
            <button
              type="button"
              id="card-view-locale-trigger"
              class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--language"
              aria-label="{{ t('cardEditor.localeLabel') }}"
              aria-haspopup="menu"
              aria-expanded="false"
              aria-controls="card-view-locale-menu"
              data-workspace-target="viewLocaleButton"
              data-action="click->workspace#toggleViewLocaleMenu keydown->workspace#handleViewLocaleTriggerKeydown"
            >
              <span class="sr-only">{{ t('cardEditor.localeLabel') }}</span>
            </button>

            <div
              id="card-view-locale-menu"
              class="view-locale-menu"
              role="menu"
              hidden
              data-workspace-target="viewLocaleMenu"
              data-action="keydown->workspace#handleViewLocaleMenuKeydown"
            ></div>

            <label class="sr-only" for="card-view-locale-select">{{ t('cardEditor.localeLabel') }}</label>
            <select
              id="card-view-locale-select"
              class="sr-only"
              hidden
              tabindex="-1"
              aria-hidden="true"
              data-action="change->workspace#changeViewLocale"
              data-workspace-target="viewLocaleSelect"
            ></select>
          </div>
        </div>

        <button
          type="button"
          class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--copy"
          hidden
          disabled
          aria-label="{{ t('cardViewDialog.copyButton') }}"
          data-workspace-target="viewCopyButton"
          data-action="workspace#copyViewCardDetails"
          aria-disabled="true"
        >
          <span class="sr-only">{{ t('cardViewDialog.copyButton') }}</span>
        </button>

        <button
          type="button"
          class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--edit"
          hidden
          disabled
          aria-disabled="true"
          aria-label="{{ t('cardViewDialog.editButton') }}"
          data-workspace-target="viewEditButton"
          data-action="workspace#openEditFromView"
        >
          <span class="sr-only">{{ t('cardViewDialog.editButton') }}</span>
        </button>

        <button
          type="button"
          class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--close"
          aria-label="{{ t('common.close') }}"
          data-view-dialog-initial-focus
          data-action="workspace#closeViewDialog"
        >
          <span class="sr-only">{{ t('common.close') }}</span>
        </button>
      </div>
    </div>

    <h2 class="mt-4 font-serif text-3xl text-strong" data-workspace-target="viewCardTitle">
      {{ t('cardViewDialog.titlePlaceholder') }}
    </h2>

    <div class="mt-6 space-y-4">
      <p class="text-sm leading-6 text-strong" hidden data-workspace-target="viewReviewState"></p>

      <button
        type="button"
        class="touch-button-secondary"
        hidden
        data-workspace-target="viewRequestVerificationButton"
        data-action="workspace#requestViewLocaleReview"
      >
        {{ t('cardViewDialog.requestHumanVerificationButton') }}
      </button>

      <div class="space-y-4">
        <div class="space-y-2">
          <div class="markdown-rendered text-sm leading-6 text-muted" data-workspace-target="viewCardBody"></div>
        </div>

        <div class="grid justify-items-center">
          <p class="card-item-meta text-xs uppercase tracking-[0.24em] text-subtle">
            <span class="card-item-meta-icon" aria-hidden="true"></span>
            <span data-workspace-target="viewCardUpdated"></span>
          </p>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-3 pt-2" hidden data-workspace-target="viewActionRegion"></div>
    </div>
  </div>
</dialog>

<dialog
  class="sheet-dialog"
  data-workspace-target="viewDialog"
  data-action="click->workspace#backdropCloseViewDialog cancel->workspace#closeViewDialog"
>
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div class="min-w-0 space-y-2">
        <div class="space-y-2" data-workspace-target="viewCardPrioritySection">
          <dd class="text-sm leading-6 text-strong" data-workspace-target="viewCardPriority"></dd>
        </div>
        <h2 class="font-serif text-3xl text-strong" data-workspace-target="viewCardTitle">
          {{ t('cardViewDialog.titlePlaceholder') }}
        </h2>
      </div>

      <button
        type="button"
        class="touch-button-secondary"
        data-view-dialog-initial-focus
        data-action="workspace#closeViewDialog"
      >
        {{ t('common.close') }}
      </button>
    </div>

    <div class="mt-6 space-y-4">
      <label class="block space-y-2" hidden data-workspace-target="viewLocaleSection">
        <span class="field-label text-sm font-semibold">{{ t('cardEditor.localeLabel') }}</span>
        <select
          id="card-view-locale-select"
          class="field-control"
          data-action="change->workspace#changeViewLocale"
          data-workspace-target="viewLocaleSelect"
        ></select>
      </label>

      <p class="text-sm leading-6 text-strong" hidden data-workspace-target="viewReviewState"></p>

      <button
        type="button"
        class="touch-button-secondary"
        hidden
        data-workspace-target="viewRequestVerificationButton"
        data-action="workspace#requestViewLocaleReview"
      >
        {{ t('cardViewDialog.requestHumanVerificationButton') }}
      </button>

      <dl class="space-y-4">
        <div class="space-y-2">
          <dt class="field-label text-sm font-semibold">{{ t('cardViewDialog.detailsLabel') }}</dt>
          <dd class="markdown-rendered text-sm leading-6 text-muted" data-workspace-target="viewCardBody"></dd>
        </div>

        <div class="space-y-2">
          <dt class="field-label text-sm font-semibold">{{ t('cardViewDialog.updatedLabel') }}</dt>
          <dd class="text-sm leading-6 text-muted" data-workspace-target="viewCardUpdated"></dd>
        </div>
      </dl>

      <div class="flex flex-wrap items-center gap-3 pt-2" hidden data-workspace-target="viewActionRegion">
        <button
          type="button"
          class="touch-button-secondary"
          hidden
          data-workspace-target="viewPromptRunButton"
          data-action="workspace#handleRunStagePromptFromView"
        >
          {{ t('workspace.cardPromptRunButton') }}
        </button>
      </div>
    </div>
  </div>
</dialog>

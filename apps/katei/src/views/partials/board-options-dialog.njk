<dialog
  class="sheet-dialog"
  data-controller="board-options"
  data-board-options-target="dialog"
  data-action="
    workspace:open-board-options@window->board-options#openFromEvent
    workspace:sync-board-options@window->board-options#syncFromEvent
    click->board-options#backdropClose
    cancel->board-options#close
  "
>
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div class="min-w-0 space-y-2">
        <p class="field-label text-sm font-semibold">Boards</p>
        <h2 class="font-serif text-3xl text-strong">Board options</h2>
        <p class="text-sm leading-6 text-muted" data-board-options-target="summary"></p>
      </div>

      <button
        type="button"
        class="touch-button-secondary"
        data-board-options-initial-focus
        data-action="board-options#close"
      >
        Close
      </button>
    </div>

    <section class="mt-6 space-y-3">
      <p class="field-label text-sm font-semibold">Switch board</p>
      <ul class="space-y-3" data-board-options-target="boardList"></ul>
    </section>

    <template data-board-options-target="boardItemTemplate">
      <li class="paper-panel px-4 py-4">
        <div class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
          <div class="min-w-0 space-y-1">
            <p class="text-base text-strong" data-board-options-field="title">Board title</p>
            <p class="text-xs uppercase tracking-[0.24em] text-subtle" data-board-options-field="state">Active</p>
          </div>

          <button
            type="button"
            class="touch-button-secondary"
            data-board-options-field="switchButton"
            data-action="board-options#switchBoard"
          >
            Switch
          </button>
        </div>
      </li>
    </template>

    <div class="dialog-actions mt-6">
      <button type="button" class="touch-button-primary" data-action="board-options#createBoard">New Board</button>
      <button type="button" class="touch-button-secondary" data-action="board-options#renameBoard">Rename Board</button>
      <button type="button" class="touch-button-secondary" data-action="board-options#resetBoard">Reset Board</button>
      <button
        type="button"
        class="touch-button-danger"
        hidden
        data-board-options-target="deleteButton"
        data-action="board-options#deleteBoard"
      >
        Delete Board
      </button>
    </div>

    <div
      class="dialog-actions mt-4"
      data-controller="session"
      data-session-auth-url-value="/auth/logout"
      data-session-redirect-url-value="/"
    >
      <button type="button" class="touch-button-secondary" data-action="session#logout">Logout</button>
      <p class="sr-only" aria-live="polite" data-session-target="status"></p>
    </div>
  </div>
</dialog>

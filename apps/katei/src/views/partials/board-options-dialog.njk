<dialog
  class="sheet-dialog"
  data-controller="board-options"
  data-board-options-target="dialog"
  data-action="
    workspace:open-board-options@window->board-options#openFromEvent
    workspace:sync-board-options@window->board-options#syncFromEvent
    click->board-options#backdropClose
    cancel->board-options#close
  "
>
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div class="min-w-0 space-y-2">
        <p class="field-label text-sm font-semibold">{{ t('boardOptionsDialog.sectionLabel') }}</p>
        <h2 class="font-serif text-3xl text-strong">{{ t('boardOptionsDialog.heading') }}</h2>
        <p class="text-sm leading-6 text-muted" data-board-options-target="summary"></p>
        <p class="text-xs uppercase tracking-[0.24em] text-subtle" data-board-options-target="roleSummary"></p>
        <p class="text-xs leading-5 text-muted" hidden data-board-options-target="pendingSummary"></p>
      </div>

      <button
        type="button"
        class="touch-button-secondary"
        data-board-options-initial-focus
        data-action="board-options#close"
      >
        {{ t('common.close') }}
      </button>
    </div>

    <section class="mt-6 space-y-3">
      <p class="field-label text-sm font-semibold">{{ t('boardOptionsDialog.switchBoardLabel') }}</p>
      <ul class="space-y-3" data-board-options-target="boardList"></ul>
    </section>

    <section class="mt-6 space-y-3" hidden data-board-options-target="inviteSection">
      <p class="field-label text-sm font-semibold">{{ t('boardOptionsDialog.invitesHeading') }}</p>
      <ul class="space-y-3" data-board-options-target="inviteList"></ul>
    </section>

    <template data-board-options-target="boardItemTemplate">
      <li class="paper-panel px-4 py-4">
        <div class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
          <div class="min-w-0 space-y-1">
            <p class="text-base text-strong" data-board-options-field="title">{{ t('boardOptionsDialog.boardTitlePlaceholder') }}</p>
            <p class="text-xs uppercase tracking-[0.24em] text-subtle" data-board-options-field="state">
              {{ t('boardOptionsDialog.activeStatePlaceholder') }}
            </p>
          </div>

          <div class="action-wrap-grid sm:justify-self-end">
            <button
              type="button"
              class="touch-button-secondary"
              data-board-options-field="switchButton"
              data-action="board-options#switchBoard"
            >
              {{ t('boardOptionsDialog.switchButton') }}
            </button>
            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-board-options-field="renameButton"
              data-action="board-options#renameBoard"
            >
              {{ t('boardOptionsDialog.renameBoard') }}
            </button>
            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-board-options-field="inviteAcceptButton"
              data-action="board-options#acceptInvite"
            >
              {{ t('boardOptionsDialog.acceptInviteButton') }}
            </button>
            <button
              type="button"
              class="touch-button-secondary"
              hidden
              data-board-options-field="inviteDeclineButton"
              data-action="board-options#declineInvite"
            >
              {{ t('boardOptionsDialog.declineInviteButton') }}
            </button>
          </div>
        </div>
      </li>
    </template>

    <template data-board-options-target="inviteItemTemplate">
      <li class="paper-panel px-4 py-4">
        <div class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
          <div class="min-w-0 space-y-1">
            <p class="text-base text-strong" data-board-options-field="inviteTitle">{{ t('boardOptionsDialog.boardTitlePlaceholder') }}</p>
            <p class="text-sm leading-6 text-muted" data-board-options-field="inviteMeta"></p>
            <p class="text-xs uppercase tracking-[0.24em] text-subtle" data-board-options-field="inviteRole"></p>
          </div>

          <div class="action-wrap-grid sm:justify-self-end">
            <button
              type="button"
              class="touch-button-secondary"
              data-board-options-field="inviteAcceptButton"
              data-action="board-options#acceptInvite"
            >
              {{ t('boardOptionsDialog.acceptInvite') }}
            </button>
            <button
              type="button"
              class="touch-button-secondary"
              data-board-options-field="inviteDeclineButton"
              data-action="board-options#declineInvite"
            >
              {{ t('boardOptionsDialog.declineInvite') }}
            </button>
          </div>
        </div>
      </li>
    </template>

    <div class="dialog-actions board-options-actions mt-6">
      <button type="button" class="touch-button-primary" data-action="board-options#createBoard">
        {{ t('boardOptionsDialog.newBoard') }}
      </button>
      <button
        type="button"
        class="touch-button-secondary"
        data-board-options-target="collaboratorsButton"
        data-action="board-options#openCollaborators"
      >
        {{ t('boardOptionsDialog.collaboratorsButton') }}
        <span class="count-chip ml-2 px-2 py-0.5 text-xs" hidden data-board-options-target="collaboratorBadge">0</span>
      </button>
      <button
        type="button"
        class="touch-button-danger"
        hidden
        data-board-options-target="deleteButton"
        data-action="board-options#deleteBoard"
      >
        {{ t('boardOptionsDialog.deleteBoard') }}
      </button>
    </div>
  </div>
</dialog>

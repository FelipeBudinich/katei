<main
  class="portfolio-page"
  data-controller="portfolio"
  data-portfolio-viewer-sub-value="{{ viewer.sub or '' }}"
  data-portfolio-viewer-super-admin-value="{{ 'true' if canManageBoardSelfRoles else 'false' }}"
>
  <p class="sr-only" role="status" aria-live="polite" data-portfolio-target="announcer"></p>
  <section class="portfolio-hero paper-panel">
    <div class="landing-utility-row">
      {% include "partials/ui-locale-badge.njk" %}
      {% set uiLocalePickerId = 'portfolio-ui-locale-picker' %}
      {% include "partials/ui-locale-picker.njk" %}
    </div>

    <div class="portfolio-header">
      <div class="portfolio-copy">
        <p class="landing-eyebrow">{{ t('portfolio.eyebrow') }}</p>
        <h1 class="font-serif text-5xl leading-none text-strong sm:text-6xl">{{ t('portfolio.title') }}</h1>
        <p class="max-w-3xl text-base leading-7 text-muted sm:text-lg">
          {{ t('portfolio.description') }}
        </p>
      </div>

      <div class="portfolio-actions">
        <a href="/boards" class="touch-button-secondary">{{ t('portfolio.openBoards') }}</a>
      </div>
    </div>

    <div class="portfolio-meta-row">
      {% include "partials/viewer-chip.njk" %}

      <div class="portfolio-badge-row">
        {% if viewer.isSuperAdmin %}
          <span class="portfolio-badge portfolio-badge--accent">{{ t('portfolio.superAdminBadge') }}</span>
        {% endif %}
        <span class="portfolio-badge">{{ t('portfolio.readOnlyBadge') }}</span>
      </div>
    </div>
  </section>

  <section class="paper-panel portfolio-section">
    <div class="portfolio-section-header">
      <h2 class="font-serif text-3xl text-strong">{{ t('portfolio.summary.heading') }}</h2>
      <p class="text-sm leading-6 text-muted">{{ t('portfolio.summary.description') }}</p>
    </div>

    <div class="portfolio-summary-grid">
      {% for item in summaryItems %}
        <article class="portfolio-summary-card">
          <span class="portfolio-summary-label">{{ item.label }}</span>
          <strong class="portfolio-summary-value">{{ item.value }}</strong>
        </article>
      {% endfor %}
    </div>
  </section>

  <section class="paper-panel portfolio-section">
    <div class="portfolio-section-header">
      <h2 class="font-serif text-3xl text-strong">{{ t('portfolio.directory.heading') }}</h2>
      <p class="text-sm leading-6 text-muted">{{ t('portfolio.directory.description') }}</p>
    </div>

    <div class="portfolio-toolbar">
      <form method="get" action="/portfolio" class="portfolio-search-form">
        <label for="portfolio-search" class="field-label text-sm font-semibold">
          {{ t('portfolio.filters.searchLabel') }}
        </label>
        <input
          id="portfolio-search"
          name="q"
          type="search"
          value="{{ portfolioFilters.searchQuery }}"
          class="portfolio-search-input"
          placeholder="{{ t('portfolio.filters.searchPlaceholder') }}"
        >
        <div class="portfolio-search-actions">
          <button type="submit" class="touch-button-secondary">{{ t('portfolio.filters.applyAction') }}</button>
          {% if portfolioFilters.hasSearchQuery %}
            <a href="/portfolio" class="touch-button-secondary">{{ t('portfolio.filters.clearAction') }}</a>
          {% endif %}
        </div>
      </form>

      {% if boardDirectoryEntries.length %}
        <p class="portfolio-results-label">
          {{ t('portfolio.filters.resultsLabel', { count: boardDirectoryCount }) }}
        </p>
      {% endif %}
    </div>

    {% if boardDirectoryEntries.length %}
      <div class="portfolio-directory-groups">
        {% for group in boardDirectoryWorkspaceGroups %}
          <article class="portfolio-workspace-group portfolio-directory-card">
            <div class="portfolio-workspace-header">
              <div class="portfolio-workspace-header-copy">
                <div class="portfolio-workspace-title-row">
                  <h3
                    class="font-serif text-2xl text-strong"
                    data-portfolio-field="workspace-label"
                    data-portfolio-workspace-id="{{ group.workspaceId }}"
                    data-portfolio-workspace-fallback-label="{{ group.workspaceId }}"
                  >
                    {{ group.workspaceLabel }}
                  </h3>

                  {% if canManageWorkspaceTitles %}
                    <button
                      type="button"
                      class="touch-button-secondary"
                      data-action="portfolio#openRenameDialog"
                      data-portfolio-action="rename-workspace-title"
                      data-workspace-id="{{ group.workspaceId }}"
                      data-workspace-title="{{ group.workspaceTitle }}"
                      data-workspace-fallback-label="{{ group.workspaceId }}"
                    >
                      {{ t(group.workspaceTitle and 'portfolio.workspaceTitleEditor.editAction' or 'portfolio.workspaceTitleEditor.assignAction') }}
                    </button>
                  {% endif %}
                </div>

                <p class="portfolio-table-secondary">
                  {{ t('portfolio.directory.workspaceIdLabel') }}: {{ group.workspaceId }}
                </p>
              </div>
            </div>

            <div class="portfolio-table-wrap">
              <table class="portfolio-table">
                <thead>
                  <tr>
                    <th scope="col">{{ t('portfolio.directory.boardColumnLabel') }}</th>
                    <th scope="col">{{ t('portfolio.directory.localeCoverageColumnLabel') }}</th>
                    <th scope="col">{{ t('portfolio.directory.keyCountsColumnLabel') }}</th>
                    <th scope="col">{{ t('portfolio.directory.actionsColumnLabel') }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for entry in group.entries %}
                    <tr>
                      <td>
                        <div class="portfolio-table-primary">{{ entry.title }}</div>
                        <p class="portfolio-table-secondary">{{ t('portfolio.directory.boardIdLabel') }}: {{ entry.boardId }}</p>
                      </td>
                      <td>
                        <div class="portfolio-locale-coverage">
                          <span class="portfolio-status-badge {{ entry.localeCoverage.statusModifierClass }}">
                            {{ entry.localeCoverage.statusLabel }}
                          </span>
                          <p class="portfolio-table-secondary">
                            {{ t('portfolio.directory.sourceLocaleLabel') }}: {{ entry.localeCoverage.sourceLocale }}
                          </p>
                          <p class="portfolio-table-secondary">
                            {{ t('portfolio.directory.defaultLocaleLabel') }}: {{ entry.localeCoverage.defaultLocale }}
                          </p>
                          <p class="portfolio-table-secondary">
                            {{ t('portfolio.directory.supportedLocalesLabel') }}: {{ entry.localeCoverage.supportedLocales }}
                          </p>
                          <p class="portfolio-table-secondary">
                            {{ t('portfolio.directory.requiredLocalesLabel') }}: {{ entry.localeCoverage.requiredLocales }}
                          </p>
                        </div>
                      </td>
                      <td>
                        <ul class="portfolio-count-list">
                          {% for count in entry.counts %}
                            <li class="portfolio-count-item">
                              <span>{{ count.label }}</span>
                              <strong class="text-strong">{{ count.value }}</strong>
                            </li>
                          {% endfor %}
                        </ul>
                      </td>
                      <td>
                        {% if canManageBoardSelfRoles %}
                          {% set selfRoleSelectId = 'portfolio-self-role-' ~ entry.workspaceId ~ '-' ~ entry.boardId %}
                          <form
                            class="portfolio-board-role-form"
                            data-portfolio-board-role-form
                            data-workspace-id="{{ entry.workspaceId }}"
                            data-board-id="{{ entry.boardId }}"
                            data-board-title="{{ entry.title }}"
                            data-current-role="{{ entry.selfRole.key }}"
                            data-action="change->portfolio#handleBoardSelfRoleInput submit->portfolio#saveBoardSelfRole"
                          >
                            <label for="{{ selfRoleSelectId }}" class="field-label text-sm font-semibold">
                              {{ t('portfolio.boardSelfRole.fieldLabel') }}
                            </label>
                            <p
                              class="portfolio-table-secondary"
                              data-portfolio-field="board-self-role-current-value"
                              data-role="{{ entry.selfRole.key }}"
                            >
                              {{ t('collaborators.currentRoleValue', { role: entry.selfRole.label }) }}
                            </p>
                            <div class="portfolio-board-role-controls">
                              <select
                                id="{{ selfRoleSelectId }}"
                                class="field-control portfolio-board-role-select"
                                data-portfolio-field="board-self-role-select"
                              >
                                <option value="" disabled {% if not entry.selfRole.selectValue %}selected{% endif %}>
                                  {{ t('portfolio.boardSelfRole.selectPlaceholder') }}
                                </option>
                                <option value="viewer" {% if entry.selfRole.selectValue == 'viewer' %}selected{% endif %}>
                                  {{ t('collaborators.roles.viewer') }}
                                </option>
                                <option value="editor" {% if entry.selfRole.selectValue == 'editor' %}selected{% endif %}>
                                  {{ t('collaborators.roles.editor') }}
                                </option>
                                <option value="admin" {% if entry.selfRole.selectValue == 'admin' %}selected{% endif %}>
                                  {{ t('collaborators.roles.admin') }}
                                </option>
                              </select>
                              <button
                                type="submit"
                                class="touch-button-secondary"
                                data-portfolio-field="board-self-role-save"
                                {% if not entry.selfRole.selectValue %}disabled{% endif %}
                              >
                                {{ t('portfolio.boardSelfRole.saveAction') }}
                              </button>
                            </div>
                            <p
                              class="portfolio-table-secondary"
                              data-portfolio-field="board-open-hint"
                              {% if entry.canOpenBoard %}hidden{% endif %}
                            >
                              {{ t('portfolio.boardSelfRole.openBoardHelp') }}
                            </p>
                            <p class="portfolio-dialog-status text-sm" hidden data-portfolio-field="board-self-role-error"></p>
                            <a
                              href="{{ entry.openBoardHref }}"
                              class="touch-button-secondary{% if not entry.canOpenBoard %} portfolio-link-disabled{% endif %}"
                              data-portfolio-open-board-link
                              data-action="portfolio#openBoardFromPortfolio"
                              aria-disabled="{{ 'false' if entry.canOpenBoard else 'true' }}"
                              {% if not entry.canOpenBoard %}tabindex="-1"{% endif %}
                            >
                              {{ t('portfolio.directory.openBoardAction') }}
                            </a>
                          </form>
                        {% else %}
                          <a href="{{ entry.openBoardHref }}" class="touch-button-secondary">{{ t('portfolio.directory.openBoardAction') }}</a>
                        {% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="portfolio-empty-state">
        {% if portfolioFilters.hasSearchQuery %}
          <h3 class="font-serif text-2xl text-strong">{{ t('portfolio.directory.emptyFiltered.heading') }}</h3>
          <p class="text-sm leading-6 text-muted">{{ t('portfolio.directory.emptyFiltered.description') }}</p>
        {% else %}
          <h3 class="font-serif text-2xl text-strong">{{ t('portfolio.empty.heading') }}</h3>
          <p class="text-sm leading-6 text-muted">{{ t('portfolio.empty.description') }}</p>
        {% endif %}
      </div>
    {% endif %}
  </section>

  <section class="paper-panel portfolio-section">
    <div class="portfolio-section-header">
      <h2 class="font-serif text-3xl text-strong">{{ t('portfolio.awaitingApproval.heading') }}</h2>
      <p class="text-sm leading-6 text-muted">{{ t('portfolio.awaitingApproval.description') }}</p>
    </div>

    {% if awaitingApprovalEntries.length %}
      <p class="portfolio-results-label">
        {{ t('portfolio.filters.resultsLabel', { count: awaitingApprovalCount }) }}

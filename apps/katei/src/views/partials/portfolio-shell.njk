      <div class="portfolio-table-wrap">
        <table class="portfolio-table">
          <thead>
            <tr>
              <th scope="col">{{ t('portfolio.awaitingApproval.workspaceColumnLabel') }}</th>
              <th scope="col">{{ t('portfolio.awaitingApproval.boardColumnLabel') }}</th>
              <th scope="col">{{ t('portfolio.awaitingApproval.cardColumnLabel') }}</th>
              <th scope="col">{{ t('portfolio.awaitingApproval.localeColumnLabel') }}</th>
              <th scope="col">{{ t('portfolio.awaitingApproval.stateColumnLabel') }}</th>
              <th scope="col">{{ t('portfolio.awaitingApproval.verificationRequestedAtColumnLabel') }}</th>
              <th scope="col">{{ t('portfolio.awaitingApproval.actionsColumnLabel') }}</th>
            </tr>
          </thead>
          <tbody>
            {% for entry in awaitingApprovalEntries %}
              <tr>
                <td>
                  <div
                    class="portfolio-table-primary"
                    data-portfolio-field="workspace-label"
                    data-portfolio-workspace-id="{{ entry.workspaceId }}"
                    data-portfolio-workspace-fallback-label="{{ entry.workspaceId }}"
                  >
                    {{ entry.workspaceLabel }}
                  </div>
                </td>
                <td><div class="portfolio-table-primary">{{ entry.boardTitle }}</div></td>
                <td>
                  <div class="portfolio-table-primary">{{ entry.cardTitle }}</div>
                  {% if entry.localizedTitle %}
                    <p class="portfolio-table-secondary">{{ entry.localizedTitle }}</p>
                  {% endif %}
                </td>
                <td><div class="portfolio-table-primary">{{ entry.locale }}</div></td>
                <td><div class="portfolio-table-primary">{{ entry.stateLabel }}</div></td>
                <td>
                  <p class="portfolio-table-secondary">{{ entry.timestampLabel }}</p>
                  <div class="portfolio-table-primary">{{ entry.timestamp }}</div>
                </td>
                <td>
                  <a href="{{ entry.openBoardHref }}" class="touch-button-secondary">{{ t('portfolio.awaitingApproval.openBoardAction') }}</a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <div class="portfolio-empty-state">
        {% if portfolioFilters.hasSearchQuery %}
          <h3 class="font-serif text-2xl text-strong">{{ t('portfolio.awaitingApproval.emptyFiltered.heading') }}</h3>
          <p class="text-sm leading-6 text-muted">{{ t('portfolio.awaitingApproval.emptyFiltered.description') }}</p>
        {% else %}
          <h3 class="font-serif text-2xl text-strong">{{ t('portfolio.awaitingApproval.empty.heading') }}</h3>
          <p class="text-sm leading-6 text-muted">{{ t('portfolio.awaitingApproval.empty.description') }}</p>
        {% endif %}
      </div>
    {% endif %}
  </section>


  <section class="paper-panel portfolio-section">
    <div class="portfolio-section-header">
      <h2 class="font-serif text-3xl text-strong">{{ t('portfolio.aging.heading') }}</h2>
      <p class="text-sm leading-6 text-muted">{{ t('portfolio.aging.description') }}</p>
    </div>

    <div class="portfolio-subsection-list">
      {% for section in agingSections %}
        <div class="portfolio-subsection">
          <div class="portfolio-section-header">
            <h3 class="font-serif text-2xl text-strong">{{ section.heading }}</h3>
            <p class="text-sm leading-6 text-muted">{{ section.description }}</p>
          </div>

          {% if section.entries.length %}
            <p class="portfolio-results-label">
              {{ t('portfolio.filters.resultsLabel', { count: section.count }) }}
            </p>

            <div class="portfolio-workspace-groups">
              {% for group in section.workspaceGroups %}
                <article class="portfolio-workspace-group paper-panel">
                  <div class="portfolio-workspace-header">
                    <div class="portfolio-workspace-header-copy">
                      <h4
                        class="font-serif text-2xl text-strong"
                        data-portfolio-field="workspace-label"
                        data-portfolio-workspace-id="{{ group.workspaceId }}"
                        data-portfolio-workspace-fallback-label="{{ group.workspaceId }}"
                      >
                        {{ group.workspaceLabel }}
                      </h4>
                    </div>
                  </div>

                  <div class="portfolio-table-wrap">
                    <table class="portfolio-table">
                      <thead>
                        <tr>
                          <th scope="col">{{ t('portfolio.aging.boardColumnLabel') }}</th>
                          <th scope="col">{{ section.countLabel }}</th>
                          <th scope="col">{{ section.timestampLabel }}</th>
                          <th scope="col">{{ section.actionsLabel }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for entry in group.entries %}
                          <tr>
                            <td><div class="portfolio-table-primary">{{ entry.boardTitle }}</div></td>
                            <td><div class="portfolio-table-primary">{{ entry.count }}</div></td>
                            <td><div class="portfolio-table-primary">{{ entry.timestamp }}</div></td>
                            <td>
                              <a href="{{ entry.openBoardHref }}" class="touch-button-secondary">{{ section.openBoardAction }}</a>
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </article>
              {% endfor %}
            </div>
          {% else %}
            <div class="portfolio-empty-state">
              <h4 class="font-serif text-2xl text-strong">{{ section.emptyHeading }}</h4>
              <p class="text-sm leading-6 text-muted">{{ section.emptyDescription }}</p>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </section>

  {% if canManageWorkspaceTitles %}
    <dialog
      class="sheet-dialog"
      data-portfolio-target="dialog"
      data-action="click->portfolio#backdropClose cancel->portfolio#close"
    >
      <div class="sheet-panel">
        <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

        <div class="dialog-header-row mt-4">
          <div>
            <h2 class="font-serif text-3xl text-strong" data-portfolio-target="heading">
              {{ t('portfolio.workspaceTitleEditor.assignHeading') }}
            </h2>
          </div>
          <button
            type="button"
            class="touch-button-secondary touch-button-secondary--icon touch-button-secondary--close"
            aria-label="{{ t('common.close') }}"
            data-action="portfolio#close"
            data-portfolio-target="closeButton"
          >
            <span class="sr-only">{{ t('common.close') }}</span>
          </button>
        </div>

        <form class="mt-6 space-y-5" data-action="submit->portfolio#saveWorkspaceTitle">
          <label class="block space-y-2">
            <span class="field-label text-sm font-semibold">{{ t('portfolio.workspaceTitleEditor.fieldLabel') }}</span>
            <input
              type="text"
              class="field-control"
              placeholder="{{ t('portfolio.workspaceTitleEditor.placeholder') }}"
              data-action="input->portfolio#handleTitleInput"
              data-portfolio-target="titleInput"
            >
          </label>

          <p class="text-xs leading-5 text-muted">{{ t('portfolio.workspaceTitleEditor.help') }}</p>
          <p class="portfolio-dialog-status text-sm" hidden data-portfolio-target="error"></p>

          <div class="dialog-actions board-options-actions mt-6">
            <button type="button" class="touch-button-secondary" data-action="portfolio#close" data-portfolio-target="cancelButton">
              {{ t('common.cancel') }}
            </button>
            <button type="submit" class="touch-button-primary" data-portfolio-target="saveButton">
              {{ t('common.save') }}
            </button>
          </div>
        </form>
      </div>
    </dialog>
  {% endif %}

  {% set profileOptionsShowLocaleBadge = true %}
  {% set profileOptionsUiLocalePickerId = 'portfolio-ui-locale-picker' %}
  {% set profileOptionsUiLocalePickerAction = '/portfolio' %}
  {% include "partials/profile-options-dialog.njk" %}
</main>

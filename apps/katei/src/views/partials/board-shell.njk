<header class="top-bar">
  <div class="min-w-0">
    <div class="top-bar-title-row">
      <h1 class="font-serif text-3xl leading-tight text-strong" data-workspace-target="boardTitle">{{ board.title }}</h1>
      <button type="button" class="touch-button-secondary" data-action="workspace#openBoardOptions">Options</button>
    </div>
  </div>

  <div class="top-bar-actions">
    {% if viewer %}
      <div class="viewer-chip">
        {% if viewer.picture %}
          <img
            src="{{ viewer.picture }}"
            alt=""
            class="viewer-chip-avatar"
            width="44"
            height="44"
            loading="lazy"
            referrerpolicy="no-referrer"
          >
        {% else %}
          <span class="viewer-chip-avatar viewer-chip-avatar--fallback" aria-hidden="true">
            {{ (viewer.name or viewer.sub) | first | upper }}
          </span>
        {% endif %}
        <div class="viewer-chip-copy">
          <span class="viewer-chip-label">Signed in</span>
          <span class="viewer-chip-name">{{ viewer.name or viewer.sub }}</span>
        </div>
      </div>
    {% endif %}

    <div
      data-controller="session"
      data-session-auth-url-value="/auth/logout"
      data-session-redirect-url-value="/"
    >
      <button type="button" class="touch-button-secondary" data-action="session#logout">Logout</button>
      <p class="sr-only" aria-live="polite" data-session-target="status"></p>
    </div>

    <button type="button" class="touch-button-primary" data-action="workspace#openCreateCard">Add Card</button>
  </div>
</header>

<section class="board-columns grid gap-4" data-workspace-target="desktopColumns">
  {% include "partials/desktop-board.njk" %}
</section>

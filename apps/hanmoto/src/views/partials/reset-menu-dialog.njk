<dialog
  class="sheet-dialog confirm-dialog"
  data-board-target="resetMenuDialog"
  data-action="click->board#backdropCloseResetMenu cancel->board#closeResetMenu"
>
  <div class="confirm-panel">
    <div class="space-y-2">
      <h2 class="font-serif text-3xl text-strong">Board options</h2>
      <p class="text-sm leading-6 text-muted">Reset the board when you want to clear all saved cards and start fresh.</p>
    </div>

    <div class="confirm-actions dialog-actions mt-6">
      <button type="button" class="touch-button-secondary" data-reset-menu-initial-focus data-action="board#closeResetMenu">Close</button>
      <button type="button" class="touch-button-danger" data-action="board#resetBoard">Reset</button>
    </div>
  </div>
</dialog>

<dialog
  class="sheet-dialog confirm-dialog"
  data-board-target="confirmDialog"
  data-action="click->board#backdropCloseConfirmDialog cancel->board#closeConfirmDialog"
>
  <div class="confirm-panel">
    <div class="space-y-2">
      <h2 class="font-serif text-3xl text-strong" data-board-target="confirmTitle">Delete card?</h2>
      <p class="text-sm leading-6 text-muted" data-board-target="confirmMessage">This action cannot be undone.</p>
    </div>

    <div class="confirm-actions dialog-actions mt-6">
      <button type="button" class="touch-button-secondary" data-action="board#closeConfirmDialog">Cancel</button>
      <button type="button" class="touch-button-danger" data-board-target="confirmButton" data-action="board#confirmPendingAction">Delete</button>
    </div>
  </div>
</dialog>

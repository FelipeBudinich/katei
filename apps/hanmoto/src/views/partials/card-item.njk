<article class="card-item" data-card-id="{{ card.id }}" data-column-id="{{ columnId }}" data-priority="{{ card.priority }}">
  <header class="card-item-toolbar">
    <button
      type="button"
      class="card-item-action px-3"
      aria-label="Edit card"
      data-action="board#openEdit"
      data-card-id="{{ card.id }}"
      data-column-id="{{ columnId }}"
    >
      <span class="card-item-action-icon" aria-hidden="true"></span>
    </button>

    <h3 class="card-item-title text-base text-strong" data-card-field="title">{{ card.title }}</h3>

    <button
      type="button"
      class="card-item-action px-3"
      aria-label="View card"
      data-action="board#openView"
      data-card-id="{{ card.id }}"
      data-column-id="{{ columnId }}"
    >
      <span class="card-item-view-icon" aria-hidden="true"></span>
    </button>
  </header>

  <div class="card-item-body">
    <p
      class="text-sm leading-6 text-muted{% if not card.description %} hidden{% endif %}"
      data-card-field="description"
    >
      {{ card.description }}
    </p>
  </div>

  <footer class="card-item-footer">
    <p class="card-item-meta text-xs uppercase tracking-[0.24em] text-subtle">
      <span class="card-item-meta-icon" aria-hidden="true"></span>
      <span data-card-field="meta">{{ card.updatedAt }}</span>
    </p>
  </footer>
</article>

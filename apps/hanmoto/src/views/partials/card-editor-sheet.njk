<dialog
  class="sheet-dialog"
  data-controller="card-editor"
  data-action="board:open-editor@window->card-editor#openFromEvent click->card-editor#backdropClose cancel->card-editor#close"
  data-card-editor-target="dialog"
>
  <div class="sheet-panel">
    <div class="dialog-handle mx-auto h-1.5 w-16 rounded-full lg:hidden"></div>

    <div class="dialog-header-row mt-4">
      <div>
        <h2 class="font-serif text-3xl text-strong" data-card-editor-target="heading">New card</h2>
      </div>
      <button type="button" class="touch-button-secondary" data-action="card-editor#close">Close</button>
    </div>

    <form class="mt-6 space-y-4" data-card-editor-target="form" data-action="submit->card-editor#submit">
      <input type="hidden" name="mode" value="create" data-card-editor-target="modeInput">
      <input type="hidden" name="cardId" value="" data-card-editor-target="cardIdInput">
      <input type="hidden" name="sourceColumnId" value="" data-card-editor-target="sourceColumnIdInput">
      <input type="hidden" name="targetColumnId" value="backlog" data-card-editor-target="targetColumnIdInput">
      <input type="hidden" name="priority" value="important" data-card-editor-target="priorityInput">

      <label class="block space-y-2">
        <span class="field-label text-sm font-semibold">Title</span>
        <input
          type="text"
          name="title"
          class="field-control"
          placeholder="What needs doing?"
          required
          data-card-editor-target="titleInput"
        >
      </label>

      <label class="block space-y-2">
        <span class="field-label text-sm font-semibold">Description</span>
        <textarea
          name="description"
          rows="4"
          class="field-control"
          placeholder="Optional context, notes, or next steps."
          data-card-editor-target="descriptionInput"
        ></textarea>
      </label>

      <section class="space-y-3 pt-2" data-card-editor-target="prioritySection">
        <p class="field-label text-sm font-semibold">Priority</p>

        <div class="priority-dot-group" role="group" aria-label="Priority">
          {% for priority in priorityDefinitions %}
            <button
              type="button"
              class="priority-dot"
              data-card-editor-target="priorityOption"
              data-priority-id="{{ priority.id }}"
              data-priority-label="{{ priority.label }}"
              aria-label="{{ priority.label }}"
              aria-pressed="false"
              title="{{ priority.label }}"
              data-action="card-editor#selectPriority"
            >
              <span class="sr-only">{{ priority.label }}</span>
            </button>
          {% endfor %}
        </div>
      </section>

      <section class="space-y-3 pt-2" hidden data-card-editor-target="editActions">
        <div class="space-y-2">
          <p class="field-label text-sm font-semibold">Task Status</p>
          <div class="action-wrap-grid mt-3" data-card-move-options>
            {% for targetColumn in columnDefinitions %}
              <button
              type="button"
              class="touch-button-secondary"
              data-card-editor-target="moveOption"
              data-column-title="{{ targetColumn.title }}"
              data-target-column-id="{{ targetColumn.id }}"
              data-action="card-editor#selectColumn"
            >
              {{ targetColumn.title }}
            </button>
            {% endfor %}
          </div>
        </div>
      </section>

      <section class="pt-2" hidden data-card-editor-target="deleteActions">
        <div class="action-wrap-grid">
          <div class="action-region-contents" data-card-editor-target="deleteActionRegion"></div>
        </div>

        <template data-card-editor-target="deleteButtonTemplate">
          <button
            type="button"
            class="touch-button-danger"
            data-action="card-editor#closeForAction board#deleteCard"
          >
            Delete
          </button>
        </template>
      </section>

      <div class="dialog-actions pt-2">
        <button type="submit" class="touch-button-primary">Save Card</button>
      </div>
    </form>
  </div>
</dialog>

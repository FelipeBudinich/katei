<main
  class="mx-auto grid min-h-screen w-full max-w-7xl content-start gap-4 px-4 pb-10 pt-4 sm:px-6 lg:px-8"
  data-controller="board"
  data-action="card-editor:save->board#handleEditorSave"
>
  <header class="top-bar">
    <div class="min-w-0">
      <div class="top-bar-title-row">
        <h1 class="font-serif text-3xl leading-tight text-strong" data-board-target="boardTitle">{{ board.title }}</h1>
        <button type="button" class="touch-button-secondary" data-action="board#openResetMenu">Options</button>
      </div>
    </div>

    <button type="button" class="fab-button" data-action="board#openCreate">+ Add Card</button>
  </header>

  <section class="board-columns grid gap-4" data-board-target="desktopColumns">
    {% include "partials/desktop-board.njk" %}
  </section>

  <div class="sr-only" aria-live="polite" data-board-target="announcer"></div>

  {% include "partials/card-editor-sheet.njk" %}
  {% include "partials/card-view-dialog.njk" %}
  {% include "partials/reset-menu-dialog.njk" %}
  {% include "partials/confirm-dialog.njk" %}
  {% include "partials/board-templates.njk" %}
</main>

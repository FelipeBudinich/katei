{
  "ignoreGlobs": [
    "**/node_modules/**",
    "**/doc/*.json",
    "**/.generated/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/src/public/**",
    "**/public/**",
    "**/.github/**",
    "**/.agents/**"
  ],
  "extraScanRoots": [],
  "sharedRoots": [
    "packages/*",
    "libs/*"
  ],
  "docRoots": [
    "README*",
    "doc/**/*"
  ],
  "publicPrefixes": [
    "NEXT_PUBLIC_",
    "VITE_",
    "PUBLIC_"
  ],
  "secretLikePatterns": [
    "KEY",
    "SECRET",
    "TOKEN",
    "PASSWORD",
    "PWD",
    "PRIVATE",
    "DATABASE_URL"
  ],
  "appPathOverrides": {}
}
